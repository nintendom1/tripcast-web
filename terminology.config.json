{
  "scanRoots": [
    "src",
    "README.md",
    "package.json",
    "../tripcast-backend/convex",
    "../tripcast-backend/README.md",
    "../tripcast-backend/package.json"
  ],
  "exclude": [
    "**/.git/**",
    "**/.github/**",
    "**/.convex/**",
    "**/.agents/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/generated/**",
    "**/_generated/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.mjs",
    "**/*.map",
    "**/*.lock"
  ],
  "rules": [
    {
      "id": "people-support-crew",
      "term": "Support Crew",
      "replacement": "Follower",
      "category": "People",
      "reason": "Use Follower for the person following a trip.",
      "pattern": "\\bSupport Crew\\b"
    },
    {
      "id": "people-crew",
      "term": "Crew",
      "replacement": "Follower",
      "category": "People",
      "reason": "Drop Crew and Support Crew in user-facing terminology.",
      "pattern": "\\bCrew\\b"
    },
    {
      "id": "mission-challenges-title",
      "term": "Challenges",
      "replacement": "Missions",
      "category": "Missions",
      "reason": "Mission replaces Challenge.",
      "pattern": "\\bChallenges\\b"
    },
    {
      "id": "mission-challenge-title",
      "term": "Challenge",
      "replacement": "Mission",
      "category": "Missions",
      "reason": "Mission replaces Challenge.",
      "pattern": "\\bChallenge\\b"
    },
    {
      "id": "journal-history-title",
      "term": "History",
      "replacement": "Journal",
      "category": "Journal / Stories",
      "reason": "Journal is the main trip story/history section.",
      "pattern": "\\bHistory\\b"
    },
    {
      "id": "story-check-in-item-title",
      "term": "Check-in",
      "replacement": "Story",
      "category": "Journal / Stories",
      "reason": "Use Story for completed narrative content items; Check In remains the action.",
      "pattern": "\\bCheck-in\\b"
    },
    {
      "id": "map-map-marker-user-copy",
      "term": "map marker",
      "replacement": "Pin",
      "category": "Map",
      "reason": "Use Pin in user-facing map copy.",
      "pattern": "\\bmap marker\\b"
    },
    {
      "id": "options-debug-mode",
      "term": "Debug Mode",
      "replacement": "Debug Log",
      "category": "Options / Debug",
      "reason": "Debug Log is the debug/logging tool name.",
      "pattern": "\\bDebug Mode\\b"
    },
    {
      "id": "options-logging-mode",
      "term": "Logging Mode",
      "replacement": "Debug Log",
      "category": "Options / Debug",
      "reason": "Debug Log is the debug/logging tool name.",
      "pattern": "\\bLogging Mode\\b"
    }
  ],
  "allowlist": [
    {
      "ruleId": "map-map-marker-user-copy",
      "path": "src/features/map/**",
      "reason": "Map implementation code may use MapLibre marker terminology."
    },
    {
      "ruleId": "*",
      "path": "**/README.md",
      "lineContains": "terminology baseline",
      "reason": "Terminology docs may refer to lint concepts."
    }
  ]
}
