{
  "name": "tripcast-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "npm": ">=11.10.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:cap": "tsc -b && vite build --mode capacitor",
    "ios:sync": "npm run build:cap && cap sync ios",
    "ios:run": "npm run build:cap && cap sync ios && cap run ios",
    "ios:assets": "npx --yes @capacitor/assets@latest generate --ios",
    "validate": "npm run lint:terms:report && tsc -b && eslint . && vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:terms:report": "node scripts/lintTerms.mjs --mode=report",
    "lint:terms:baseline": "node scripts/lintTerms.mjs --mode=baseline",
    "lint:terms": "node scripts/lintTerms.mjs --mode=enforce",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "vitest run --project=node",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor/cli": "8.4.0",
    "@capacitor/core": "8.4.0",
    "@capacitor/ios": "8.4.0",
    "@capacitor/status-bar": "8.0.2",
    "@capgo/background-geolocation": "8.0.40",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.38.0",
    "dayjs": "^1.11.20",
    "exifreader": "^4.41.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-medium-image-zoom": "^5.4.5",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
